{
  "name": "information-classification-for-confluence",
  "version": "0.1.0",
  "main": "index.js",
  "license": "AGPLv3",
  "private": true,
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint src/**/*",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "cpd": "jscpd src/",
    "test:e2e": "npx playwright test --config=e2e/playwright.config.js",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.{js,jsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md,yml,yaml}": [
      "prettier --write"
    ]
  },
  "devDependencies": {
    "@playwright/test": "^1.40.0",
    "@vitest/coverage-v8": "^4.1.2",
    "dotenv": "^16.3.0",
    "eslint": "^9.37.0",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^5.0.0",
    "husky": "^9.1.7",
    "jscpd": "^4.0.8",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.1",
    "vitest": "^4.0.18"
  },
  "dependencies": {
    "@forge/bridge": "5.8.0",
    "@forge/events": "^2.1.2",
    "@forge/kvs": "^1.5.0",
    "@forge/react": "11.14.0",
    "@forge/realtime": "^0.3.2",
    "@forge/resolver": "1.7.1",
    "react": "^18.2.0"
  },
  "overrides": {
    "@atlaskit/analytics-next-stable-react-context": {
      "react": "$react"
    },
    "react-scrolllock": {
      "react": "$react"
    }
  }
}
